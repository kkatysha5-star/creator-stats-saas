# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use default path (backend/data.db)
DB_PATH=

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
# Get free key at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Free quota: 10,000 units/day (~1,000 video fetches)
YOUTUBE_API_KEY=

# ─── TikTok Research API ──────────────────────────────────────────────────────
# Apply at: https://developers.tiktok.com/products/research-api/
# Requires business verification (~2 weeks). Access token via OAuth 2.0.
TIKTOK_ACCESS_TOKEN=

# ─── Instagram Graph API ──────────────────────────────────────────────────────
# Requires: Facebook Developer App + Instagram Business/Creator accounts
# Guide: https://developers.facebook.com/docs/instagram-api/getting-started
# Each creator needs to authorize your app and you store their access token
INSTAGRAM_ACCESS_TOKEN=
